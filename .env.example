# Interactive Brokers Configuration
# Set either the direct value or the matching *_FILE path, not both.
IB_USER=
IB_USER_FILE=
IB_PASSWORD=
IB_PASSWORD_FILE=

# Trading Configuration
TRADING_MODE=paper
ACCEPT_NON_BROKERAGE_WARNING=yes
READ_ONLY_API=no
TIME_ZONE=UTC

# VNC Configuration
# Leave VNC_PWD and VNC_PWD_FILE empty to keep VNC disabled.
VNC_PWD=
VNC_PWD_FILE=
VNC_PORT=5900
TWS_VNC_PORT=5901
VNC_SCREEN_DIMENSION=1600x1200x24

# Startup hooks
# Paths must be absolute. Executable *.sh files run in sorted order.
START_SCRIPTS=
X_SCRIPTS=
IBC_SCRIPTS=

# IBC Configuration
FIX=no
FIX_LOGIN_ID=
FIX_PASSWORD=
SECOND_FACTOR_DEVICE=
TWOFA_TIMEOUT_ACTION=exit
SECOND_FACTOR_AUTH_TIMEOUT=180
EXIT_AFTER_TWOFA_TIMEOUT=no
LOGIN_DIALOG_DISPLAY_TIMEOUT=60
IB_DIR=
STORE_SETTINGS_ON_SERVER=yes
MINIMIZE_MAIN_WINDOW=no
EXISTING_SESSION_DETECTED_ACTION=manual
OVERRIDE_TWS_API_PORT=
OVERRIDE_TWS_MASTER_CLIENT_ID=
READ_ONLY_LOGIN=no
AUTO_RESTART_TIME=
AUTO_LOGOFF_TIME=
COLD_RESTART_TIME=
CLOSEDOWN_AT=
BYPASS_WARNING=yes
ACCEPT_BID_ASK_LAST_SIZE_DISPLAY_UPDATE=
SEND_MARKET_DATA_IN_LOTS_FOR_US_STOCKS=
TRUSTED_TWS_API_CLIENT_IPS=
RESET_ORDER_IDS_AT_START=
CONFIRM_ORDER_ID_RESET=
ACCEPT_INCOMING_CONNECTION_ACTION=manual
ALLOW_BLIND_TRADING=no
SAVE_TWS_SETTINGS=Every 30 mins
CONFIRM_CRYPTO_CURRENCY_ORDERS=manual
DISMISS_PASSWORD_EXPIRY_WARNING=no
DISMISS_NSE_COMPLIANCE_NOTICE=yes
INCLUDE_STACK_TRACE_FOR_EXCEPTIONS=yes
COMMAND_SERVER_PORT=0
CONTROL_FROM=
BIND_ADDRESS=
COMMAND_PROMPT=
SUPPRESS_INFO_MESSAGES=yes
LOG_STRUCTURE_SCOPE=known
LOG_STRUCTURE_WHEN=never
RELOGIN_AFTER_TWOFA_TIMEOUT=no
TWOFA_EXIT_INTERVAL=60

# Java Runtime Configuration
# Leave JAVA_HEAP_SIZE empty to auto-size from container memory.
JAVA_HEAP_SIZE=
CUSTOM_JVM_OPTS=
